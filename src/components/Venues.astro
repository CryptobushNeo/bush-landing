---
const venues = ['Binance', 'Bybit', 'Hyperliquid', 'Polymarket'];
const tags = ['Perpetuals', 'Spot', 'On-chain', 'Prediction markets'];
---

<section class="venues" id="venues">
  <div class="wrap">
    <p class="v-label" data-reveal>Trading across centralized & decentralized venues</p>
  </div>
  <div class="v-marquee" aria-hidden="true">
    <div class="v-track">
      {[...venues, ...venues, ...venues].map((v) => (
        <span class="v-item">{v}<span class="v-star">✦</span></span>
      ))}
    </div>
  </div>
  <div class="wrap">
    <div class="v-tags">
      {tags.map((t, i) => <span class="v-tag" data-reveal data-reveal-delay={0.05 * i}>{t}</span>)}
    </div>
  </div>
</section>

<style>
  .venues { padding-block: clamp(3rem, 6vw, 5rem); }
  .v-label {
    text-align: center; font-family: var(--font-display);
    font-size: 0.85rem; letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--muted-2); margin-bottom: 2.5rem;
  }
  .v-marquee {
    overflow: hidden;
    mask-image: linear-gradient(90deg, transparent, #000 12%, #000 88%, transparent);
    border-block: 1px solid var(--panel-brd);
    padding-block: 1.6rem;
  }
  .v-track { display: inline-flex; gap: 3rem; white-space: nowrap; animation: vscroll 30s linear infinite; }
  .v-item {
    display: inline-flex; align-items: center; gap: 1.4rem;
    font-family: var(--font-display); font-weight: 600;
    font-size: clamp(1.5rem, 3.4vw, 2.6rem); color: var(--text);
  }
  .v-star { color: var(--gold); font-size: 0.6em; }
  @keyframes vscroll { to { transform: translateX(-33.33%); } }

  .v-tags { display: flex; flex-wrap: wrap; gap: 0.7rem; justify-content: center; margin-top: 2.5rem; }
  .v-tag {
    font-family: var(--font-display); font-size: 0.82rem; color: var(--muted);
    padding: 0.5em 1.1em; border: 1px solid var(--panel-brd); border-radius: 100px;
    background: var(--panel);
  }
</style>
