---
// Replace FORM_ID with your Formspree form id (formspree.io) — no backend needed.
const FORM_ENDPOINT = 'https://formspree.io/f/FORM_ID';
---

<section class="section-pad" id="contact">
  <div class="wrap contact">
    <div class="c-left">
      <p class="eyebrow" data-reveal>Get in touch</p>
      <h2 class="display c-title" data-reveal data-reveal-delay="0.05">
        Put capital<br />on the <span class="grad-text">path.</span>
      </h2>
      <p class="lede" data-reveal data-reveal-delay="0.1">
        We work with a limited number of aligned partners. If you allocate to systematic
        digital-asset strategies — or want to understand how we think — start a conversation.
      </p>
      <p class="c-alt" data-reveal data-reveal-delay="0.15">
        Prefer email? <a href="mailto:partners@bush.finance">partners@bush.finance</a>
      </p>
    </div>

    <form class="c-form" action={FORM_ENDPOINT} method="POST" data-reveal data-reveal-delay="0.1">
      <div class="c-field">
        <label for="name">Name</label>
        <input id="name" name="name" type="text" required autocomplete="name" placeholder="Jane Street" />
      </div>
      <div class="c-field">
        <label for="email">Email</label>
        <input id="email" name="email" type="email" required autocomplete="email" placeholder="you@fund.com" />
      </div>
      <div class="c-field">
        <label for="org">Organization <span class="opt">(optional)</span></label>
        <input id="org" name="organization" type="text" placeholder="Firm / family office" />
      </div>
      <div class="c-field">
        <label for="msg">Message</label>
        <textarea id="msg" name="message" rows="4" required placeholder="A little about your mandate…"></textarea>
      </div>
      <button type="submit" class="btn btn-gold c-submit">Send inquiry</button>
      <p class="c-fine">By submitting you agree to be contacted about Cryptobush. We never share your details.</p>
    </form>
  </div>
</section>

<style>
  .contact { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(2.5rem, 6vw, 6rem); align-items: start; }
  .c-title { font-size: clamp(2.4rem, 5.5vw, 4.4rem); margin: 1rem 0 1.6rem; }
  .c-alt { margin-top: 1.6rem; color: var(--muted); }
  .c-alt a { color: var(--gold); border-bottom: 1px solid rgba(245,197,24,0.35); }

  .c-form {
    background: linear-gradient(180deg, rgba(255,255,255,0.04), rgba(255,255,255,0.01));
    border: 1px solid var(--panel-brd);
    border-radius: 22px;
    padding: clamp(1.6rem, 3vw, 2.4rem);
  }
  .c-field { margin-bottom: 1.1rem; display: flex; flex-direction: column; gap: 0.5rem; }
  .c-field label {
    font-family: var(--font-display); font-size: 0.82rem; font-weight: 500;
    letter-spacing: 0.04em; color: var(--muted);
  }
  .opt { color: var(--muted-2); }
  .c-field input, .c-field textarea {
    font-family: var(--font-body); font-size: 1rem; color: var(--text);
    background: rgba(10,7,19,0.5);
    border: 1px solid var(--panel-brd); border-radius: 12px;
    padding: 0.85em 1em; transition: border-color 0.25s, box-shadow 0.25s;
    resize: vertical;
  }
  .c-field input::placeholder, .c-field textarea::placeholder { color: var(--muted-2); }
  .c-field input:focus, .c-field textarea:focus {
    outline: none; border-color: var(--violet-400);
    box-shadow: 0 0 0 3px rgba(124,58,237,0.18);
  }
  .c-submit { width: 100%; justify-content: center; margin-top: 0.4rem; }
  .c-fine { color: var(--muted-2); font-size: 0.78rem; margin-top: 0.9rem; text-align: center; }

  @media (max-width: 820px) { .contact { grid-template-columns: 1fr; } }
</style>
